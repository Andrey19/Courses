<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bd_rounded_card"
    app:cardBackgroundColor="@color/dark"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="236dp"
        android:background="@color/dark_grey">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_top_section"
            android:layout_width="match_parent"
            android:layout_height="114dp"
            android:background="@drawable/rounded_image"
            android:clipToOutline="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/course_image"
                android:scaleType="centerCrop"
                android:src="@drawable/course_image"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_favourite_flag_oval"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/favourite_flag"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_favourite_flag"
                    android:contentDescription="@string/favourite_flag_image"
                    android:scaleType="center"
                    android:src="@drawable/favorite_flag_unmarked" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="84dp"
                android:background="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_gravity="start"
                    android:background="@drawable/rounded_info"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <ImageView
                        android:id="@+id/rating_star"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginEnd="4dp"
                        android:contentDescription="@string/rate_star_image"
                        android:src="@drawable/rate_star" />

                    <TextView
                        android:id="@+id/rating"
                        style="@style/AndroidCaption"
                        android:layout_width="wrap_content"
                        android:layout_height="14dp"
                        android:layout_gravity="end|center_vertical"
                        android:text="@string/rating_value_example"
                        android:textColor="@color/white"
                        android:tooltipText="4.9" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_gravity="end"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/rounded_info"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <TextView
                        android:id="@+id/date_published"
                        style="@style/AndroidCaption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/date_example"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/card_bottom_section"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="130dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/courseName"
                style="@style/AndroidTitleMedium"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:text="@string/course_name"
                android:textColor="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:id="@+id/courseDescription"
                    style="@style/AndroidBodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:alpha="0.7"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/courses_description"
                    android:textColor="@color/white"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/price"
                    style="@style/AndroidTitleMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    android:text="@string/price_example"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/detail"
                        style="@style/AndroidButtonSmallDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/detail"
                        android:textColor="@color/green" />

                    <ImageView
                        android:id="@+id/arrow_right"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@string/right_arrow_image"
                        android:scaleType="fitXY"
                        android:src="@drawable/arrow_right_short_fill" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>