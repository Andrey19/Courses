<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark"
    android:paddingHorizontal="16dp">


    <LinearLayout
        android:id="@+id/searchGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/searchContainer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/rounded_edittext"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:id="@+id/searchImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:contentDescription="@string/search_image"
                android:src="@drawable/ic_search" />

            <TextView
                android:id="@+id/searchInput"
                style="@style/AndroidCourseBodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:alpha="0.5"
                android:text="@string/search_courses"
                android:textColor="@color/white" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/funnelButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/rounded_edittext"
            android:backgroundTint="@null"
            android:contentDescription="@string/funnel_image"
            android:scaleType="center"
            android:src="@drawable/funnel" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/sortButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchGroup">

        <TextView
            android:id="@+id/sortByPublishDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/data_add"
            android:textColor="@color/green" />

        <ImageView
            android:id="@+id/arrowImage"
            android:layout_width="11dp"
            android:layout_height="13dp"
            android:layout_gravity="center"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/up_down_arrow_image"
            android:src="@drawable/arrow_down_up" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sortButton"
        tools:listitem="@layout/card_course" />

</androidx.constraintlayout.widget.ConstraintLayout>